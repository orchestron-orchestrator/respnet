actor netinfra_tester(done: action(?bool, ?Exception)->None, log_handler: logging.Handler):
    xmlin = """<data>
    <netinfra xmlns="http://example.com/netinfra">
        <routers>
            <name>AMS-CORE-1</name>
            <id>1</id>
            <role>edge</role>
            <mock>cisco-ios-xr</mock>
        </routers>
        <routers>
            <name>FRA-CORE-1</name>
            <id>2</id>
            <role>core</role>
            <mock>cisco-ios-xr</mock>
        </routers>
        <backbone-link>
            <left-router>AMS-CORE-1</left-router>
            <left-interface>GigabitEthernet0/0/0/0</left-interface>
            <right-router>FRA-CORE-1</right-router>
            <right-interface>GigabitEthernet0/0/0/0</right-interface>
        </backbone-link>
    </netinfra>
</data>"""
    xml_conf = xml.decode(xmlin)
    input_config = cfs_root.from_xml(xml_conf)

    dev_mgr = odev.DeviceManager(log_handler=log_handler)
    stack = respnet.layers.get_layers(dev_mgr, log_handler)
    session = stack.newsession()

    def cont1(_r: value):
        #r2 = session.below().below().get()
        #print("OUTPUT:", r2.prsrc())
        r3 = session.below().below().below().get()
        #print(r3.prsrc())
        testing.assertEqual(r3, netinfra1_out)
        done(True, None)

    session.edit_config(input_config.to_gdata(), cont1)

def _test_netinfra1(done, log_handler: logging.Handler):
    netinfra_tester(done, log_handler)


l3vpn_out = gdata.Container({
  'devices': gdata.Container({
    'device': gdata.List(['name'], [
      gdata.ListElement(['AMS-CORE-1'], {
        'name': gdata.Leaf("str", 'AMS-CORE-1'),
        'config': gdata.Container({
          'vrfs': gdata.Container(ns='http://cisco.com/ns/yang/Cisco-IOS-XR-um-vrf-cfg', children={
            'vrf': gdata.List(['vrf-name'], [
              gdata.ListElement(['VPN-1'], {
                'vrf-name': gdata.Leaf("str", 'VPN-1'),
                'address-family': gdata.Container({
                  'ipv4': gdata.Container(),
                  'ipv6': gdata.Container()
                }),
                'vpn': gdata.Container(),
                'description': gdata.Leaf("str", 'Customer VPN for CUSTOMER-1')
              })
            ])
          }),
          'interfaces': gdata.Container(ns='http://cisco.com/ns/yang/Cisco-IOS-XR-um-interface-cfg', children={
            'interface': gdata.List(['interface-name'], [
              gdata.ListElement(['GigabitEthernet0/0/0/2'], {
                'interface-name': gdata.Leaf("str", 'GigabitEthernet0/0/0/2'),
                'sub-interface-type': gdata.Container(),
                'ipv4': gdata.Container({
                  'addresses': gdata.Container(ns='http://cisco.com/ns/yang/Cisco-IOS-XR-um-if-ip-address-cfg', children={
                    'address': gdata.Container(presence=True, children={
                      'address': gdata.Leaf("str", '10.201.1.1'),
                      'netmask': gdata.Leaf("str", '255.255.255.252')
                    }),
                    'secondaries': gdata.Container({
                      'secondary': gdata.List(['address'])
                    })
                  })
                }),
                'ipv6': gdata.Container(),
                'encapsulation': gdata.Container(),
                'shutdown': gdata.Leaf("boolean", False),
                'description': gdata.Leaf("str", 'Customer VPN access SITE-1 [SNA-1-1] in VPN VPN-1'),
                'vrf': gdata.Leaf("str", 'VPN-1', ns='http://cisco.com/ns/yang/Cisco-IOS-XR-um-if-vrf-cfg')
              }),
              gdata.ListElement(['Loopback0'], {
                'interface-name': gdata.Leaf("str", 'Loopback0'),
                'sub-interface-type': gdata.Container(),
                'ipv4': gdata.Container({
                  'addresses': gdata.Container(ns='http://cisco.com/ns/yang/Cisco-IOS-XR-um-if-ip-address-cfg', children={
                    'address': gdata.Container(presence=True, children={
                      'address': gdata.Leaf("str", '10.0.0.1'),
                      'netmask': gdata.Leaf("str", '255.255.255.255')
                    }),
                    'secondaries': gdata.Container({
                      'secondary': gdata.List(['address'])
                    })
                  })
                }),
                'ipv6': gdata.Container(),
                'encapsulation': gdata.Container()
              })
            ])
          }),
          'hostname': gdata.Container(ns='http://cisco.com/ns/yang/Cisco-IOS-XR-um-hostname-cfg', children={
            'system-network-name': gdata.Leaf("str", 'AMS-CORE-1')
          })
        })
      })
    ])
  })
})

actor l3vpn_tester(done: action(?bool, ?Exception)->None, log_handler: logging.Handler):
    xmlin = """<data>
    <l3vpn-svc xmlns="urn:ietf:params:xml:ns:yang:ietf-l3vpn-svc">
        <vpn-services>
            <vpn-service>
                <vpn-id>VPN-1</vpn-id>
                <customer-name>CUSTOMER-1</customer-name>
            </vpn-service>
        </vpn-services>
        <sites>
            <site>
                <site-id>SITE-1</site-id>
                <management>
                    <type>customer-managed</type>
                </management>
                <locations>
                    <location>
                        <location-id>MAIN</location-id>
                    </location>
                </locations>
                <site-network-accesses>
                    <site-network-access>
                        <site-network-access-id>SNA-1-1</site-network-access-id>
                        <location-reference>MAIN</location-reference>
                        <service>
                            <svc-input-bandwidth>1000000000</svc-input-bandwidth>
                            <svc-output-bandwidth>1000000000</svc-output-bandwidth>
                            <svc-mtu>9000</svc-mtu>
                        </service>
                        <vpn-attachment>
                            <vpn-id>VPN-1</vpn-id>
                        </vpn-attachment>
                        <ip-connection>
                            <ipv4>
                                <address-allocation-type>static-address</address-allocation-type>
                                <addresses>
                                    <provider-address>10.201.1.1</provider-address>
                                    <prefix-length>30</prefix-length>
                                </addresses>
                            </ipv4>
                        </ip-connection>
                        <bearer>
                            <bearer-reference>AMS-CORE-1,GigabitEthernet0/0/0/2</bearer-reference>
                        </bearer>
                    </site-network-access>
                </site-network-accesses>
            </site>
        </sites>
    </l3vpn-svc>
    <netinfra xmlns="http://example.com/netinfra">
        <routers>
            <name>AMS-CORE-1</name>
            <id>1</id>
            <role>edge</role>
            <mock>cisco-ios-xr</mock>
        </routers>
    </netinfra>
</data>"""
    xml_conf = xml.decode(xmlin)
    input_config = cfs_root.from_xml(xml_conf)

    dev_mgr = odev.DeviceManager(log_handler=log_handler)
    cfs = respnet.layers.get_layers(dev_mgr, log_handler)
    rfs = cfs.below().below()
    dev_mgr.on_reconf(lambda dev: rfs.notify(['rfs', dev]))
    session = cfs.newsession()

    def cont1(_r: value):
        r3 = session.below().below().below().get()
        #print(r3.prsrc())
        testing.assertEqual(r3, l3vpn_out)
        done(True, None)

    session.edit_config(input_config.to_gdata(), cont1)

def _test_l3vpn_svc(done, log_handler: logging.Handler):
    l3vpn_tester(done, log_handler)

actor main(env):
    logh = logging.Handler("Otron")
    logh.add_sink(logging.StdoutSink())
    logh.set_output_level(logging.DEBUG)
    netinfra_tester(lambda s,e: env.exit(0), logh)

